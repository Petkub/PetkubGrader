# =====================================================
# MyGrader env. Copy to .env and fill values.
# =====================================================

# --- Postgres ---
POSTGRES_USER=mygrader
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mygrader
DATABASE_URL=postgresql+asyncpg://mygrader:change_me_strong_password@postgres:5432/mygrader

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Judge0 ---
JUDGE0_URL=http://judge0-server:2358
JUDGE0_AUTH_TOKEN=change_me_judge0_token
# Public callback URL Judge0 will POST verdicts to.
# In dev compose, fastapi resolves on judge0 network as `fastapi:8000`.
JUDGE0_CALLBACK_BASE=http://fastapi:8000

# --- FastAPI ---
API_INTERNAL_KEY=change_me_internal_shared_secret
API_CORS_ORIGINS=http://localhost,http://localhost:3000

# --- Next.js / Auth.js ---
# Generate via: openssl rand -base64 32
AUTH_SECRET=change_me_auth_secret_base64
AUTH_URL=http://localhost
# Internal: how Next.js reaches FastAPI (server-side only, never to browser).
API_INTERNAL_URL=http://fastapi:8000

# OAuth providers (fill from Google/GitHub OAuth consoles)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend for magic-link email
AUTH_RESEND_KEY=
EMAIL_FROM=onboarding@localhost

# --- Dev login (LOCAL ONLY) ---
# true = enable email-only instant login on /sign-in. NEVER true in production.
ENABLE_DEV_LOGIN=false

# --- Grader policy ---
PYTHON_TIME_MULTIPLIER=3.0
SUBMISSION_RATE_LIMIT_PER_10S=1
SUBMISSION_MAX_CONCURRENT=5
